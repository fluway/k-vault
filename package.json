{
  "name": "k-vault",
  "description": "K-Vault - Free File Hosting Service based on Telegram",
  "version": "1.0.0",
  "scripts": {
    "build": "npm run frontend:build",
    "ci-test": "concurrently --kill-others --success first \"npm start\" \"wait-on http://localhost:8080 && mocha --exit\"",
    "test": "mocha",
    "start": "npx wrangler pages dev ./ --kv \"img_url\" --r2=R2_BUCKET --compatibility-date=2026-05-03 --port 8080 --binding BASIC_USER=admin --binding BASIC_PASS=123 --persist-to ./data",
    "pages:r2:doctor": "node scripts/cloudflare-pages-r2-doctor.js",
    "pages:deploy": "npm run frontend:build && npx wrangler pages deploy frontend/dist",
    "docker:init-env": "node scripts/bootstrap-env.js",
    "server:dev": "npm --prefix server run dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:install": "npm --prefix frontend ci",
    "prefrontend:build": "npm run frontend:install",
    "frontend:build": "npm --prefix frontend run build",
    "docker:up": "npm run docker:init-env && docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:doctor": "node scripts/docker-storage-doctor.js",
    "docker:smoke:ci": "node scripts/docker-ci-smoke.js",
    "regression:storage": "node scripts/storage-regression.js"
  },
  "dependencies": {
    "@cloudflare/pages-plugin-sentry": "^1.1.4",
    "@sentry/tracing": "^7.120.4"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "hono": "^4.12.23",
    "mocha": "^11.7.6",
    "wait-on": "^9.0.10",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "@babel/runtime": "^7.29.7",
    "axios": "^1.17.0",
    "diff": "^9.0.0",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.5",
    "js-yaml": "^4.2.0",
    "lodash": "^4.18.1",
    "serialize-javascript": "^7.0.5"
  }
}
